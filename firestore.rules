rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isCaptain() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'captain';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 2. USERS COLLECTION
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId) && 
        incoming().role in ['customer', 'captain'] &&
        incoming().status in ['active', 'pending'] &&
        incoming().walletBalance == 0 &&
        incoming().uid == userId;
        
      allow update: if isOwner(userId) && 
        incoming().uid == existing().uid &&
        incoming().role == existing().role &&
        // Protect sensitive fields from self-modification if needed
        // but for now allow basic profile updates
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phone', 'isOnline', 'updatedAt', 'walletBalance', 'isVip', 'status']);
    }

    // ---------------------------------------------------------
    // 3. ORDERS COLLECTION
    // ---------------------------------------------------------
    match /orders/{orderId} {
      // Customers can see their own orders
      // Captains can see "searching" orders OR orders they accepted
      allow read: if isSignedIn() && (
        isOwner(existing().customerId) || 
        isCaptain()
      );

      allow create: if isSignedIn() && (
        incoming().customerId == request.auth.uid &&
        incoming().status == 'searching' &&
        incoming().initialPrice >= 15
      );

      allow update: if isSignedIn() && (
        // Customer can cancel their order
        (isOwner(existing().customerId) && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        // Captain can accept or progress the order
        (isCaptain() && (
          // Accept action
          (existing().status == 'searching' && incoming().status == 'accepted' && incoming().captainId == request.auth.uid) ||
          // Progress action
          (existing().captainId == request.auth.uid && incoming().status in ['picked_up', 'delivered'])
        ))
      );
    }

    // ---------------------------------------------------------
    // 4. TICKETS (Support)
    // ---------------------------------------------------------
    match /tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (isOwner(existing().userId) || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
  }
}
