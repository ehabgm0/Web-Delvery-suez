rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isCaptain() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'captain';
    }

    // Default deny for unmatched collections
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 2. USERS COLLECTION
    // ---------------------------------------------------------
    match /users/{userId} {
      // Allow read/write for signed-in owners, or phone-based backend API creations
      allow read, write: if isSignedIn() || userId.matches('^[0-9+]+$');
    }

    // ---------------------------------------------------------
    // 3. CAPTAINS COLLECTION
    // ---------------------------------------------------------
    match /captains/{captainId} {
      // Allows backend API onboarding and dynamic geolocation updates
      allow read, write: if true;
    }

    // ---------------------------------------------------------
    // 4. ORDERS COLLECTION
    // ---------------------------------------------------------
    match /orders/{orderId} {
      // Anyone can read/write an order (essential for public GPS tracking links, partner API creation, and the browser demo tracking simulator)
      allow read, write: if true;
    }

    // ---------------------------------------------------------
    // 5. TICKETS (Support)
    // ---------------------------------------------------------
    match /tickets/{ticketId} {
      allow read, write: if true;
    }
  }
}
